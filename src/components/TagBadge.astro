---
interface Props {
  tag: string;
}

const { tag } = Astro.props;

const styleMap: Record<string, string> = {
  '架构': 'bg-pineapple-100 text-pineapple-700',
  'Prompt': 'bg-blue-100 text-blue-700',
  '翻车': 'bg-red-100 text-alarm',
  '用户反馈': 'bg-green-100 text-green-700',
  '视觉': 'bg-purple-100 text-purple-700',
  '教学法': 'bg-amber-100 text-amber-700',
  '工具链': 'bg-gray-100 text-gray-700',
  '里程碑': 'bg-pineapple-500 text-ink-900',
};
const cls = styleMap[tag] ?? 'bg-gray-100 text-gray-700';
---
<span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold ${cls}`}>
  {tag}
</span>
