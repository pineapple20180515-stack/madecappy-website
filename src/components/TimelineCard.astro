---
import TagBadge from './TagBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'timeline'>;
}

const { entry } = Astro.props;
const dateStr = entry.data.date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---
<a
  href={`/timeline/${entry.id.replace(/\.mdx?$/, '')}`}
  class="block group p-6 rounded-[var(--radius-card)] border border-ink-100 hover:border-pineapple-500 hover:shadow-md transition bg-white"
>
  <div class="flex items-center gap-3 mb-3 text-xs text-ink-500">
    <time datetime={entry.data.date.toISOString()}>{dateStr}</time>
    <TagBadge tag={entry.data.tag} />
  </div>
  <h3 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-ios-blue transition">
    {entry.data.emoji && <span class="mr-2">{entry.data.emoji}</span>}
    {entry.data.title}
  </h3>
  <p class="text-ink-500 leading-relaxed">{entry.data.summary}</p>
</a>
