---
const path = Astro.url.pathname;
const navItem = (href: string, label: string) => ({
  href,
  label,
  active: path === href || (href !== '/' && path.startsWith(href)),
});
const items = [
  navItem('/timeline', '建造日记'),
  navItem('/resources', '资源'),
  navItem('/about', '关于'),
];
const communityActive = path.startsWith('/community');
---
<header class="sticky top-0 z-50 backdrop-blur-md bg-paper/80 border-b border-ink-100">
  <nav class="max-w-[var(--width-wide)] mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-lg">
      <span class="text-2xl">🎩</span>
      <span>Cappy</span>
    </a>
    <div class="flex items-center gap-4 md:gap-6 text-sm font-medium">
      {items.map(item => (
        <a
          href={item.href}
          class={`transition hover:text-ios-blue ${item.active ? 'text-ios-blue' : 'text-ink-900'}`}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/community"
        class={`
          inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full
          border transition
          ${communityActive
            ? 'bg-pineapple-500 border-pineapple-500 text-ink-900'
            : 'bg-pineapple-50 border-pineapple-300 text-ink-900 hover:bg-pineapple-100'}
        `}
      >
        <span aria-hidden="true">💬</span>
        <span>加入社群</span>
      </a>
    </div>
  </nav>
</header>
