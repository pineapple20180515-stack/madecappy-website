---
---
<section class="px-6 pt-20 pb-16 md:pt-32 md:pb-24">
  <div class="max-w-[var(--width-reading)] mx-auto text-center">
    <div class="hat-wrapper">
      <div id="cappy-bubble" class="cappy-bubble">Hi! I'm Cappy, nice to meet you!</div>
      <div id="cappy-hat" class="cappy-hat" role="img" aria-label="Cappy hat">🎩</div>
    </div>
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6">
      Cappy
    </h1>
    <p class="text-lg md:text-xl text-ink-500 leading-relaxed mb-10 max-w-xl mx-auto">
      一个父亲用 AI 给 8 岁儿子做的英语陪练 app。<br />
      不会写代码，5 个版本迭代，Building in Public。
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/timeline"
        class="inline-flex items-center px-6 py-3 rounded-full bg-pineapple-500 text-ink-900 font-semibold hover:bg-pineapple-300 transition"
      >
        看建造日记 →
      </a>
      <a
        href="/about"
        class="inline-flex items-center px-6 py-3 rounded-full border border-ink-100 hover:border-ink-500 font-semibold transition"
      >
        关于我
      </a>
    </div>
  </div>
</section>

<style>
  .hat-wrapper {
    position: relative;
    display: inline-block;
    margin-bottom: 2rem;
  }

  .cappy-hat {
    font-size: 4.5rem;
    line-height: 1;
    display: inline-block;
    cursor: pointer;
    animation: cappy-float 3.5s ease-in-out infinite;
    user-select: none;
  }

  @media (min-width: 768px) {
    .cappy-hat {
      font-size: 6rem;
    }
  }

  .cappy-hat.wobble {
    animation: cappy-wobble 0.7s ease-in-out infinite;
  }

  @keyframes cappy-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-6px) rotate(0deg); }
  }

  @keyframes cappy-wobble {
    0%   { transform: translateY(-8px) rotate(-8deg); }
    50%  { transform: translateY(-14px) rotate(8deg); }
    100% { transform: translateY(-8px) rotate(-8deg); }
  }

  .cappy-bubble {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(12px) scale(0.85);
    transform-origin: bottom center;
    background: #ffffff;
    color: var(--color-ink-900);
    padding: 10px 18px;
    border-radius: 22px;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
    box-shadow: 0 8px 24px rgba(31, 42, 61, 0.10);
    opacity: 0;
    pointer-events: none;
    white-space: nowrap;
    transition: opacity 0.25s ease, transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 10;
  }

  .cappy-bubble.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }

  /* Tail pointing down at the hat */
  .cappy-bubble::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 50%;
    width: 12px;
    height: 12px;
    background: #ffffff;
    transform: translateX(-50%) rotate(45deg);
    z-index: -1;
  }
</style>

<script>
  // Cappy 帽子靠近时挥手 + 显示气泡
  const hat = document.getElementById('cappy-hat');
  const bubble = document.getElementById('cappy-bubble');

  if (hat && bubble) {
    let isNear = false;
    const proximityThreshold = 220; // 像素

    function update(x: number, y: number) {
      const rect = hat.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dx = x - cx;
      const dy = y - cy;
      const distance = Math.sqrt(dx * dx + dy * dy);
      const shouldBeNear = distance < proximityThreshold;

      if (shouldBeNear !== isNear) {
        isNear = shouldBeNear;
        hat.classList.toggle('wobble', isNear);
        bubble.classList.toggle('visible', isNear);
      }
    }

    document.addEventListener('mousemove', (e) => update(e.clientX, e.clientY));

    // 触屏：点帽子触发，3 秒后自动收起
    let mobileTimer: number | null = null;
    hat.addEventListener('click', (e) => {
      // 桌面端如果鼠标已经在附近，点击不重复触发
      if (isNear && window.matchMedia('(hover: hover)').matches) return;

      e.preventDefault();
      const isVisible = bubble.classList.contains('visible');
      hat.classList.toggle('wobble', !isVisible);
      bubble.classList.toggle('visible', !isVisible);

      if (mobileTimer !== null) {
        clearTimeout(mobileTimer);
        mobileTimer = null;
      }
      if (!isVisible) {
        mobileTimer = window.setTimeout(() => {
          hat.classList.remove('wobble');
          bubble.classList.remove('visible');
          isNear = false;
        }, 3000);
      }
    });
  }
</script>
