---
<ProductLayout title="Privacy Policy · DualCam" description="DualCam privacy: no personal data is collected or uploaded — everything is processed locally on your device.">
  <style>
    .doc{padding:64px 0 0}
    .doc h1{font-size:clamp(28px,5vw,40px);font-weight:800;letter-spacing:-.02em;margin-bottom:8px}
    .doc .upd{color:var(--muted);font-size:14px;margin-bottom:24px}
    .doc h2{font-size:20px;font-weight:700;margin:32px 0 10px}
    .doc p,.doc li{color:#d6d6da;font-size:16px;line-height:1.8}
    .doc ul{margin:8px 0 8px 22px}
    .doc strong{color:#fff}
    .doc a{color:var(--blue)}
    .langbar{display:flex;align-items:center;gap:10px;margin-bottom:28px;flex-wrap:wrap}
    .langbar select{background:#16161a;color:#fff;border:1px solid #2c2c2e;border-radius:10px;padding:8px 12px;font-size:14px}
    .doc-lang[hidden]{display:none}
    .doc-lang[dir="rtl"]{text-align:right}
    .doc-lang[dir="rtl"] ul{margin:8px 22px 8px 0}
  </style>
  <div class="rwrap doc">
    <div class="langbar">
      <span style="color:var(--muted);font-size:14px">🌐</span>
      <select id="langSelect" aria-label="Language">
        {docs.map((d) => <option value={d.code}>{d.name}</option>)}
      </select>
    </div>

    {docs.map((d) => (
      <section class="doc-lang" data-lang={d.code} dir={d.dir} hidden>
        <h1>{d.title}</h1>
        <div class="upd">{d.updatedLabel}: {updated}</div>
        <p>{d.intro}</p>
        {d.sections.map((s) => (
          <>
            <h2>{s.h}</h2>
            <p>{s.p}</p>
            {s.bullets && (
              <ul>{s.bullets.map((b) => <li>{b}</li>)}</ul>
            )}
          </>
        ))}
      </section>
    ))}
  </div>

  <script is:inline>
    (function () {
      var sel = document.getElementById('langSelect');
      var secs = document.querySelectorAll('.doc-lang');
      var codes = Array.prototype.map.call(secs, function (s) { return s.getAttribute('data-lang'); });
      function pick() {
        var saved = localStorage.getItem('dualcam_lang');
        if (saved && codes.indexOf(saved) >= 0) return saved;
        var navs = navigator.languages || [navigator.language || 'en'];
        for (var i = 0; i < navs.length; i++) {
          var l = navs[i];
          if (codes.indexOf(l) >= 0) return l;
          var base = l.split('-')[0];
          if (base === 'zh') return (l.indexOf('TW') >= 0 || l.indexOf('HK') >= 0 || l.indexOf('Hant') >= 0) ? 'zh-Hant' : 'zh-Hans';
          if (base === 'pt') return 'pt-BR';
          for (var j = 0; j < codes.length; j++) { if (codes[j].split('-')[0] === base) return codes[j]; }
        }
        return 'en';
      }
      function show(code) {
        Array.prototype.forEach.call(secs, function (s) {
          s.hidden = (s.getAttribute('data-lang') !== code);
        });
        if (sel) sel.value = code;
        document.documentElement.lang = code;
      }
      var initial = pick();
      show(initial);
      if (sel) sel.addEventListener('change', function () {
        localStorage.setItem('dualcam_lang', sel.value);
        show(sel.value);
      });
    })();
  </script>
</ProductLayout>
