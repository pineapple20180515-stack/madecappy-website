const updated = '2026-05-30';

// 多语言隐私政策内容。每种语言一组；权限部分用 bullets 列出。
const docs = [
  {
    code: 'en', name: 'English', dir: 'ltr',
    title: 'Privacy Policy', updatedLabel: 'Last updated',
    intro: 'DualCam ("the App") takes your privacy seriously. In one line: the App does not collect, upload, or store any personal data — everything is processed locally on your device.',
    sections: [
      { h: 'What we collect', p: 'Nothing. The App has no account system, does not transmit your content over the network, and includes no third-party analytics or advertising SDKs, so we can neither see nor store any of your data.' },
      { h: 'Permissions', p: 'The App requests the following system permissions solely to provide features; all related data stays on your device:', bullets: [
        'Camera: to capture the front and back cameras at the same time and compose a video. Frames are processed locally in real time and never uploaded.',
        'Microphone: to record sound while filming. Audio is written only into your recorded video file and never uploaded.',
        'Photos (Add only): to save your recorded videos and photos to the system photo library. The App does not read other content in your library.' ] },
      { h: 'On-device AI', p: 'Face detection and person segmentation used by beauty, face masks, background blur/replacement and Me-in-Scene run entirely on your device via Apple system frameworks (Vision / Core Image). The related images never leave your device and are not uploaded to any server.' },
      { h: 'Face / biometric data', p: 'The App does not collect, process, store, or share any face data or biometric information. It only records video from the device cameras; all recordings stay on your device and are never uploaded to our servers or shared with any third party.' },
      { h: 'Your content', p: 'The videos and photos you capture are stored on your device and in your photo library, and belong to you. The App does not access, copy, or upload them.' },
      { h: "Children's privacy", p: 'The App does not collect any information from children under 13 (in fact, it collects no information from anyone).' },
      { h: 'Third parties', p: 'The App itself embeds no third-party tracking SDKs. How your media is used by other apps after being saved to your library is governed by your device and those apps’ privacy settings.' },
      { h: 'Changes', p: 'If this policy changes, we will update this page and the "Last updated" date at the top.' },
      { h: 'Contact', p: 'For any privacy questions, contact: dualcam@madecappy.com' },
    ],
  },
  {
    code: 'zh-Hans', name: '简体中文', dir: 'ltr',
