---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineCard from '../../components/TimelineCard.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('timeline', ({ data }) => !data.draft);
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const tags = [...new Set(all.map(e => e.data.tag))];
---
<BaseLayout
  title="建造日记 · Cappy"
  description="从想法到 5 个版本的真实迭代过程。"
>
  <main class="max-w-[var(--width-reading)] mx-auto px-6 py-16">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">建造日记</h1>
    <p class="text-ink-500 mb-10 leading-relaxed">
      从想法到 5 个版本的真实迭代。翻车、决策、跟 AI 工具的协作，都在这里。
    </p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-12">
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-ink-900 text-paper">全部</span>
        {tags.map(t => <TagBadge tag={t} />)}
      </div>
    )}

    <div class="space-y-6">
      {sorted.map(entry => <TimelineCard entry={entry} />)}
    </div>
  </main>
</BaseLayout>
