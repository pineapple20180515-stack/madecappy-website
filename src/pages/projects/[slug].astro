---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineCard from '../../components/TimelineCard.astro';
import { getCollection, render } from 'astro:content';
import dualcamStats from '../../data/stats/dualcam.json';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map(project => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// 归属本项目的构建文章（时间线条目里 project === 当前 slug）。
const articles = (await getCollection('timeline', ({ data }) => !data.draft && data.project === project.data.slug))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 项目实时数据（由 App Store Connect 自动同步脚本写入 src/data/stats/<slug>.json）。
const statsBySlug = { dualcam: dualcamStats };
const stats = statsBySlug[project.data.slug] || null;

function trimZero(s) { return s.endsWith('.0') ? s.slice(0, -2) : s; }
function fmtNum(n) {
  if (n >= 1000000) return trimZero((n / 1000000).toFixed(1)) + 'M';
  if (n >= 10000) return trimZero((n / 1000).toFixed(1)) + 'k';
  return n.toLocaleString('en-US');
}
const curSym = { USD: '$', CNY: '¥', EUR: '€' };
function fmtMoney(n, cur) {
  return (curSym[cur] || (cur + ' ')) + (n >= 10000 ? fmtNum(n) : n.toLocaleString('en-US'));
}

const metrics = [];
if (stats) {
  if (stats.downloads != null) metrics.push({ label: '下载量', value: fmtNum(stats.downloads) });
  if (stats.paidUsers != null) metrics.push({ label: '付费用户', value: fmtNum(stats.paidUsers) });
  if (stats.revenue != null) metrics.push({ label: '累计收入', value: fmtMoney(stats.revenue, stats.currency || 'USD') });
  if (stats.rating != null) metrics.push({ label: '评分', value: '★ ' + Number(stats.rating).toFixed(1) });
}
const statsUpdated = stats && stats.updatedAt
  ? new Date(stats.updatedAt).toLocaleDateString('zh-CN')
  : null;

const statusLabel: Record<string, { text: string; color: string }> = {
  building: { text: '🟡 正在做', color: 'text-pineapple-700' },
  shipped: { text: '✅ 上线了', color: 'text-green-700' },
  paused: { text: '⏸ 暂停中', color: 'text-ink-500' },
  abandoned: { text: '❌ 放弃了', color: 'text-ink-500' },
};
const status = statusLabel[project.data.status];
---
<BaseLayout
  title={`${project.data.title} · 菠萝爸爸的 AI 实践`}
  description={project.data.tagline}
>
  <section class="max-w-[var(--width-reading)] mx-auto px-6 pt-16 pb-8">
    <a href="/projects" class="text-sm text-ios-blue hover:underline">← 全部项目</a>
    <div class="mt-4 flex items-start gap-4">
      <div class="text-6xl flex-shrink-0">{project.data.coverEmoji || '📦'}</div>
      <div class="flex-1 min-w-0">
        <h1 class="text-3xl md:text-4xl font-black mb-2">{project.data.title}</h1>
        <p class="text-lg text-ink-500 mb-3">{project.data.tagline}</p>
        <div class="flex flex-wrap items-center gap-3 text-sm">
          <span class={status.color + ' font-semibold'}>{status.text}</span>
          {project.data.forWhom && (
            <span class="text-ink-500">· {project.data.forWhom}</span>
          )}
          {project.data.externalUrl && (
            <a href={project.data.externalUrl} target="_blank" rel="noopener" class="text-ios-blue hover:underline">访问 →</a>
          )}
        </div>
        {project.data.techStack.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {project.data.techStack.map(t => (
              <span class="text-xs px-2 py-1 rounded-full bg-ink-100 text-ink-500">{t}</span>
            ))}
          </div>
        )}
        {project.data.productPath && (
          <a
            href={project.data.productPath}
            class="inline-flex items-center gap-1.5 mt-5 px-5 py-2.5 rounded-full bg-ink-900 text-paper text-sm font-semibold hover:bg-ios-blue transition"
          >
            产品介绍 →
          </a>
        )}
      </div>
    </div>
  </section>

  {stats && (
    <section class="max-w-[var(--width-reading)] mx-auto px-6 pb-4">
      {metrics.length > 0 ? (
        <div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            {metrics.map(m => (
              <div class="text-center rounded-2xl border border-ink-100 bg-white py-5 px-2">
                <div class="text-2xl md:text-3xl font-extrabold text-pineapple-700">{m.value}</div>
                <div class="text-xs text-ink-500 mt-1">{m.label}</div>
              </div>
            ))}
          </div>
          <p class="text-xs text-ink-400 mt-3">
            数据来自 {stats.source || 'App Store Connect'}{statsUpdated ? ` · 更新于 ${statsUpdated}` : ''}
          </p>
        </div>
      ) : (
        <p class="text-sm text-ink-400 rounded-2xl border border-dashed border-ink-200 py-5 text-center">
          📊 实时数据接入中（App Store Connect 自动同步）
        </p>
      )}
    </section>
  )}

  <main class="max-w-[var(--width-reading)] mx-auto px-6 pb-16 prose prose-lg prose-cappy">
    <Content />
  </main>

  {articles.length > 0 && (
    <section class="max-w-[var(--width-reading)] mx-auto px-6 pb-20">
      <h2 class="text-2xl font-extrabold mb-6">构建笔记</h2>
      <div class="space-y-6">
        {articles.map(entry => <TimelineCard entry={entry} />)}
      </div>
    </section>
  )}
</BaseLayout>
